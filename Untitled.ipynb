    "import torch\n",
    "\n",
    "from src.nomto import NOMTO\n",
    "from src.nomto_config import NOMTOConfig\n",
    "\n",
    "\n",
    "cfg = NOMTOConfig()\n",
    "\n",
    "model = NOMTO(cfg).to(cfg.device)\n",
    "\n",
    "x = torch.randn(16, cfg.n_input_fields, 256, device=cfg.device)\n",
    "\n",
    "y = model(x)\n",
    "\n",
    "print(y.shape)\n",
    "print(model.count_active_edges())"
   ]
